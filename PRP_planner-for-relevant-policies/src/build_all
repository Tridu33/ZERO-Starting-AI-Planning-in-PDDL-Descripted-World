#! /bin/bash

# Unset environment variables that interfere with header search paths.
# CPLUS_INCLUDE_PATH and C_INCLUDE_PATH can cause system C headers to be
# found before libc++ wrapper headers, breaking compilation on macOS.
unset CPLUS_INCLUDE_PATH
unset C_INCLUDE_PATH
unset CPATH

cd preprocess
make "$@" || exit 1
cd ..

cd search
make "$@" || exit 1
cd ..

# Skip building VAL altogether (no point in fixing at this point)
exit

if [ ! -e VAL ]; then
    # Skip building validator if it isn't present.
    exit
fi

type flex >& /dev/null
if [ $? != 0 ]; then
    echo cannot build validator: flex not found
    exit 1
fi

type bison >& /dev/null
if [ $? != 0 ]; then
    echo cannot build validator: bison not found
    exit 1
fi

cd VAL
make "$@" || exit 1
strip validate
cp validate ../
cd ..
